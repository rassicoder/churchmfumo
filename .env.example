APP_NAME="ChurchSystem API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

ADMIN_NAME="Super Admin"
ADMIN_EMAIL=admin@church.com
ADMIN_PASSWORD=password123

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_STDERR_FORMATTER=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=churchsystem
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SESSION_DOMAIN=localhost

# Railway production example:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-app.up.railway.app
# LOG_CHANNEL=stderr
# LOG_STDERR_FORMATTER=\Monolog\Formatter\JsonFormatter
# DB_CONNECTION=mysql
# SESSION_DOMAIN=your-app.up.railway.app
# SANCTUM_STATEFUL_DOMAINS=your-app.up.railway.app

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@churchsystem.local
MAIL_FROM_NAME="${APP_NAME}"
